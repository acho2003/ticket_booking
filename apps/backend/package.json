{
  "name": "@bhutan/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && prisma generate && tsc -p tsconfig.json",
    "postinstall": "prisma generate",
    "start": "node dist/src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@bhutan/shared": "*",
    "@prisma/client": "^6.7.0",
    "append-field": "^1.0.0",
    "bcryptjs": "^3.0.2",
    "concat-map": "^0.0.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "doctrine": "^3.0.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "fs.realpath": "^1.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwa": "^2.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "prisma": "^6.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-parser": "^10.0.3",
    "swagger-ui-express": "^5.0.1",
    "utils-merge": "^1.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
