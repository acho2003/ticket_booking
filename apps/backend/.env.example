DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
PUBLIC_API_URL=http://localhost:5000
UPLOAD_DIR=uploads

# Supabase notes:
# - Use the pooler DATABASE_URL above for the running backend.
# - If Prisma migrate fails with the pooler URL, temporarily run migrations with
#   Supabase's direct connection string from Dashboard > Connect > ORMs > Prisma.
