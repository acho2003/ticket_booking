generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  THEATRE_ADMIN
  SUPER_ADMIN
}

enum SeatType {
  REGULAR
  VIP
  COUPLE
  BLOCKED
}

enum MovieStatus {
  NOW_SHOWING
  UPCOMING
  ENDED
}

enum ShowtimeStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  RESERVED
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PAY_AT_COUNTER
  PAID
  UNPAID
}

model User {
  id                 String                   @id @default(cuid())
  name               String
  email              String                   @unique
  phone              String?
  passwordHash       String
  role               UserRole                 @default(CUSTOMER)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  bookings           Booking[]
  theatreAssignments TheatreAdminAssignment[]
}

model Theatre {
  id               String                   @id @default(cuid())
  name             String
  city             String
  location         String
  description      String?
  contactNumber    String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  screens          Screen[]
  showtimes        Showtime[]
  adminAssignments TheatreAdminAssignment[]
}

model TheatreAdminAssignment {
  id        String   @id @default(cuid())
  theatreId String
  userId    String
  createdAt DateTime @default(now())
  theatre   Theatre  @relation(fields: [theatreId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([theatreId, userId])
}

model Screen {
  id           String     @id @default(cuid())
  theatreId    String
  name         String
  totalRows    Int
  totalColumns Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  theatre      Theatre    @relation(fields: [theatreId], references: [id], onDelete: Cascade)
  seats        Seat[]
  showtimes    Showtime[]

  @@unique([theatreId, name])
}

model Seat {
  id         String   @id @default(cuid())
  screenId   String
  rowLabel   String
  seatNumber Int
  seatCode   String
  seatType   SeatType @default(REGULAR)
  isBlocked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  screen     Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  bookingSeats BookingSeat[]

  @@unique([screenId, seatCode])
}

model Movie {
  id              String       @id @default(cuid())
  title           String
  description     String
  genre           String
  language        String
  durationMinutes Int
  rating          String
  posterUrl       String
  trailerUrl      String?
  releaseDate     DateTime
  status          MovieStatus
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  showtimes       Showtime[]
}

model Showtime {
  id           String         @id @default(cuid())
  movieId      String
  theatreId    String
  screenId     String
  startTime    DateTime
  endTime      DateTime
  regularPrice Decimal        @db.Decimal(10, 2)
  vipPrice     Decimal        @db.Decimal(10, 2)
  couplePrice  Decimal        @db.Decimal(10, 2)
  status       ShowtimeStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  movie        Movie          @relation(fields: [movieId], references: [id], onDelete: Cascade)
  theatre      Theatre        @relation(fields: [theatreId], references: [id], onDelete: Cascade)
  screen       Screen         @relation(fields: [screenId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  bookingSeats BookingSeat[]
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  showtimeId    String
  bookingCode   String        @unique
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(RESERVED)
  paymentStatus PaymentStatus @default(PAY_AT_COUNTER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  showtime      Showtime      @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  bookingSeats  BookingSeat[]
}

model BookingSeat {
  id         String   @id @default(cuid())
  bookingId  String
  showtimeId String
  seatId     String
  seatCode   String
  price      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  showtime   Showtime @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  seat       Seat     @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@index([showtimeId, seatId])
  @@unique([bookingId, seatId])
}

model BookingSequence {
  id           String   @id @default(cuid())
  year         Int      @unique
  currentValue Int      @default(0)
  updatedAt    DateTime @updatedAt
}
